<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Chicken Road</title>
    <link rel="stylesheet" href="style.css">
    <!-- Telegram Web App Script -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
</head>
<body>
    <div id="game-container">
        <div id="score-board">Punkte: <span id="score">0</span></div>
        <canvas id="gameCanvas"></canvas>
        <div id="controls">
            <button id="upBtn">▲ HOCH ▲</button>
        </div>
    </div>

    <script src="game.js"></script>
    <script>
        // Signalisiert Telegram, dass die App startklar ist
        window.Telegram.WebApp.ready();
        window.Telegram.WebApp.expand(); // Macht das Spielfenster in Telegram groß
    </script>
</body>
</html>
